# vm_demo.a9 — Aether-9 VM execution demo
# Run: aether vm vm_demo.a9
# Show bytecode: aether disasm vm_demo.a9

data = [54, 36, 72, 90, 18, 45]

lattice verify(x) uses data:
    root = dr(x)
    if root == 9:
        return 9
    else:
        return 0

total = 0
for score in data:
    r = verify(score)
    total = total + r

print(total)
write("vm_report.txt", total)
