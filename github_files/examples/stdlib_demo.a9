# stdlib_demo.a9 — standard library showcase
data = [54, 36, 72, 90, 18, 45]

lattice process(x) uses data:
    return (x * 9) % 9 or 9

# arithmetic stdlib
big   = max(54, 36)
small = min(54, 36)
root  = dr(12345)

# string stdlib
label = concat("result=", str(big))
n     = len(label)

print(big)
print(small)
print(root)
print(label)
print(n)
